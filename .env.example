# LLM provider — required. All model calls run server-side; this key never reaches the browser.
# The app talks to any OpenAI-compatible endpoint via the OpenAI SDK, so the
# provider is an env-only swap (no code change).

# --- Option A: OpenAI (production target) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# Leave OPENAI_BASE_URL unset to use OpenAI's default endpoint.

# --- Option B: GLM / z.ai (used while awaiting the OpenAI key) ---
OPENAI_API_KEY=your-zai-api-key
OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/
OPENAI_MODEL=glm-4.6
